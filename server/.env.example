# Notification System Configuration
# Copy this file to .env and update with your actual credentials

# ============================================
# EMAIL CONFIGURATION (Gmail/SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@moviediscovery.app
CLIENT_URL=http://localhost:5173

# For Gmail:
# 1. Enable 2-factor authentication
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate app password for "Mail" and "Windows Computer"
# 4. Use the generated password in SMTP_PASSWORD

# Alternative Email Services:
# SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587
# Mailgun: SMTP_HOST=smtp.mailgun.org, SMTP_PORT=587
# AWS SES: SMTP_HOST=email-smtp.region.amazonaws.com, SMTP_PORT=587

# ============================================
# WEB PUSH NOTIFICATIONS (Push Service)
# ============================================
# Generate VAPID keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:support@moviediscovery.app

# ============================================
# STRIPE PAYMENT CONFIGURATION
# ============================================
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# For testing, use Stripe test keys:
# - Card: 4242 4242 4242 4242
# - Expiry: Any future date
# - CVC: Any 3 digits

# ============================================
# NOTIFICATION PREFERENCES
# ============================================
# Controls whether users can customize notification settings
ENABLE_NOTIFICATION_PREFERENCES=true

# Default frequency for new users
DEFAULT_NOTIFICATION_FREQUENCY=real-time

# Max notifications per day (rate limiting)
MAX_NOTIFICATIONS_PER_DAY=50

# ============================================
# BACKGROUND JOBS
# ============================================
# API key for secured background job endpoints
BACKGROUND_JOB_API_KEY=your_secure_random_key_here

# Schedule for watchlist availability checks (cron format)
WATCHLIST_CHECK_SCHEDULE=0 */6 * * *  # Every 6 hours

# Schedule for digest email compilation
DIGEST_EMAIL_SCHEDULE=0 9 * * 0      # Sunday at 9 AM

# ============================================
# AUDIT LOGGING
# ============================================
# Enable notification audit logs
ENABLE_NOTIFICATION_AUDIT_LOG=true

# Days to retain audit logs
AUDIT_LOG_RETENTION_DAYS=90

# Log sensitive data (emails, personal info)
LOG_SENSITIVE_DATA=false

# ============================================
# EMAIL RATE LIMITING
# ============================================
# Max emails per user per day
MAX_EMAILS_PER_DAY=10

# Max emails per hour
MAX_EMAILS_PER_HOUR=5

# ============================================
# PUSH NOTIFICATION RATE LIMITING
# ============================================
# Max push notifications per user per day
MAX_PUSH_PER_DAY=20

# Batch push notifications? (true = group similar notifications)
BATCH_PUSH_NOTIFICATIONS=true

# ============================================
# PAYMENT CONFIGURATION
# ============================================
# Subscription prices (in cents)
BASIC_MONTHLY_PRICE=499      # $4.99
BASIC_ANNUAL_PRICE=4990      # $49.90 (save 17%)
PREMIUM_MONTHLY_PRICE=999    # $9.99
PREMIUM_ANNUAL_PRICE=9990    # $99.90 (save 17%)

# Refund window (days)
REFUND_WINDOW_DAYS=30

# Auto-renewal enabled by default
AUTO_RENEW_DEFAULT=true

# ============================================
# RETRY LOGIC
# ============================================
# Number of retry attempts for failed notifications
NOTIFICATION_RETRY_ATTEMPTS=3

# Delay between retry attempts (seconds)
NOTIFICATION_RETRY_DELAY=300  # 5 minutes

# ============================================
# FEATURE FLAGS
# ============================================
# Enable/disable notification channels
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_INAPP_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false

# ============================================
# SECURITY & COMPLIANCE
# ============================================
# GDPR: Encrypt notification data
ENCRYPT_NOTIFICATION_DATA=true

# GDPR: Allow right to be forgotten
ENABLE_DATA_DELETION=true

# Data deletion delay (days before actual deletion)
DATA_DELETION_DELAY=30

# ============================================
# ERROR HANDLING
# ============================================
# Send admin alerts on critical errors
ALERT_ON_EMAIL_FAILURE=true
ALERT_ON_PAYMENT_FAILURE=true
ADMIN_EMAIL=admin@moviediscovery.app

# ============================================
# ANALYTICS
# ============================================
# Track notification open rates
TRACK_NOTIFICATION_OPENS=true

# Track email click rates
TRACK_EMAIL_CLICKS=true

# ============================================
# DEVELOPMENT
# ============================================
# Log all notification attempts to console
DEBUG_NOTIFICATIONS=false

# Use mock email service (no real emails sent)
USE_MOCK_EMAIL_SERVICE=false

# Simulate network delays (ms)
SIMULATE_NETWORK_DELAY=0

# ============================================
# DATABASE
# ============================================
# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/movie-discovery-app

# ============================================
# SERVER
# ============================================
NODE_ENV=development
PORT=5000
JWT_SECRET=your_jwt_secret_key_here
